DATABASE_URL="postgresql://postgres:postgres@localhost:5432/uni_asset_app?schema=public"
APP_BASE_URL="http://localhost:3000"

# Set true to bypass Firebase in local dev. In this mode, requests can set:
#   x-dev-user-email: you@example.edu
DEV_BYPASS_AUTH="true"
DEV_DEFAULT_USER_EMAIL="uni-admin@outlook.com"
DEV_LOCAL_ADMIN_USERNAME="admin"
# Used only for dev-bypass Basic auth (Authorization: Basic ...). Password is not stored.
DEV_LOCAL_ADMIN_PASSWORD="Admin!23456"

# Firebase Admin (server-side token verification)
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# Firebase Client (optional login page)
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""

# SMTP (required for ticket email notifications)
SMTP_HOST="smtp.office365.com"
SMTP_PORT="587"
SMTP_USER="uni-admin@outlook.com"
SMTP_PASS=""
SMTP_FROM="uni-admin@outlook.com"

# Brevo SMTP Diagnostic Suite (standalone)
# Used by scripts/smtp-diagnostic.mjs
MAIL_PROVIDER="brevo"
BREVO_SMTP_KEY=""
SENDER_EMAIL="uni-admin@outlook.com"
TEST_RECEIVER_OUTLOOK=""
# Optional overrides:
BREVO_SMTP_HOST="smtp-relay.brevo.com"
BREVO_SMTP_PORT="587"

# Optional display name in email From: header
APP_NAME="Uni Asset App"

